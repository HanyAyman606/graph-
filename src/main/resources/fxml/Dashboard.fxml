<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.trees.ui.dashboard.DashboardController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>

            <Label text="Tree Lab" styleClass="wordmark"/>
            <Label text="BST &amp; RBT Dashboard" styleClass="wordmark-sub"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblStatus" text="Ready" styleClass="status-label"/>
            <ProgressBar fx:id="globalProgress" prefWidth="140" progress="0"
                         styleClass="top-progress"/>

            <Label fx:id="lblMemory" text="Heap: — MB" styleClass="memory-label"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.25" styleClass="main-split">

            <VBox styleClass="panel-left" spacing="0">
                <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <Label text="Array Pool" styleClass="panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnGenerate" text="＋ Generate"
                            styleClass="btn-primary" onAction="#onGenerateClicked"/>
                    <Button fx:id="btnRemove"   text="✕ Remove"
                            styleClass="btn-danger"  onAction="#onRemoveClicked"/>
                </HBox>

                <ListView fx:id="poolListView" VBox.vgrow="ALWAYS" styleClass="pool-list">
                    <placeholder>
                        <Label text="No arrays yet — click ＋ Generate" />
                    </placeholder>
                </ListView>
            </VBox>

            <VBox styleClass="panel-right" spacing="0">

                <StackPane fx:id="operationsStack" styleClass="ops-stack" prefHeight="300" minHeight="250">
                    <children>
                        <VBox fx:id="placeholderPane" styleClass="placeholder-pane"
                              alignment="CENTER" spacing="10" visible="true">
                            <Label text="← Select an array from the pool" styleClass="placeholder-text"/>
                            <Label text="or generate a new one to get started."
                                   styleClass="placeholder-sub"/>
                        </VBox>

                        <VBox fx:id="noTreesPane" styleClass="placeholder-pane"
                              alignment="CENTER" spacing="16" visible="false">
                            <Label text="Trees not created yet" styleClass="placeholder-text"/>
                            <Label text="Click the button below to build BST and RBT from the selected array."
                                   styleClass="placeholder-sub" wrapText="true" maxWidth="380"
                                   alignment="CENTER"/>
                            <Button fx:id="btnCreateTrees" text="Create Trees"
                                    styleClass="btn-primary btn-large"
                                    onAction="#onCreateTreesClicked"/>
                        </VBox>

                        <VBox fx:id="operationsPane" spacing="0" visible="false">
                            <HBox styleClass="info-ribbon" spacing="20" alignment="CENTER_LEFT">
                                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                                <Label fx:id="lblSelectedName" text="—" styleClass="ribbon-name"/>
                                <Label fx:id="lblArraySize"    text="n = —" styleClass="ribbon-meta"/>
                                <Label fx:id="lblBstHeight"    text="BST h = —" styleClass="ribbon-meta"/>
                                <Label fx:id="lblRbtHeight"    text="RBT h = —" styleClass="ribbon-meta"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblLifecycle"    text="—" styleClass="lifecycle-badge"/>
                            </HBox>

                            <HBox styleClass="ops-controls" spacing="10" alignment="CENTER_LEFT">
                                <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                                <Label text="Value:" styleClass="ops-label"/>
                                <TextField fx:id="tfValue" promptText="integer" prefWidth="100" styleClass="ops-input"/>
                                <Button fx:id="btnInsert" text="Insert" styleClass="btn-insert" onAction="#onInsertClicked"/>
                                <Button fx:id="btnDelete" text="Delete" styleClass="btn-delete" onAction="#onDeleteClicked"/>
                                <Button fx:id="btnContains" text="Contains" styleClass="btn-contains" onAction="#onContainsClicked"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="btnClearLog" text="Clear Log" styleClass="btn-danger" onAction="#onClearLogClicked"/>
                            </HBox>

                            <TableView fx:id="logTable" VBox.vgrow="ALWAYS" styleClass="log-table">
                                <columns>
                                    <TableColumn fx:id="colOpId"     text="#"       prefWidth="45"/>
                                    <TableColumn fx:id="colType"     text="Op"      prefWidth="75"/>
                                    <TableColumn fx:id="colValue"    text="Value"   prefWidth="75"/>
                                    <TableColumn fx:id="colBstResult" text="BST ✓"  prefWidth="65"/>
                                    <TableColumn fx:id="colBstTime"  text="BST Time" prefWidth="95"/>
                                    <TableColumn fx:id="colRbtResult" text="RBT ✓"  prefWidth="65"/>
                                    <TableColumn fx:id="colRbtTime"  text="RBT Time" prefWidth="95"/>
                                    <TableColumn fx:id="colSpeedup"  text="Speedup" prefWidth="80"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </children>
                </StackPane>

                <HBox styleClass="section-divider" alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
                    <Label text="Benchmark Suite" styleClass="section-label"/>
                </HBox>

                <HBox styleClass="benchmark-bar" spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                    <Label text="Type:" styleClass="ops-label"/>
                    <ComboBox fx:id="cboBenchmarkType" prefWidth="130"/>
                    <Label text="Runs:" styleClass="ops-label"/>
                    <Spinner fx:id="spinnerRuns" prefWidth="75" editable="true"/>
                    <Button fx:id="btnRunBenchmark" text="▶ Run" styleClass="btn-primary" onAction="#onRunBenchmarkClicked"/>
                    <Button fx:id="btnClearBenchmark" text="Clear" styleClass="btn-danger" onAction="#onClearBenchmarkClicked"/>
                </HBox>

                <TextArea fx:id="taBenchmarkResults"
                          VBox.vgrow="ALWAYS"
                          prefHeight="450"
                          promptText="Benchmark results will appear here…"
                          styleClass="benchmark-results"
                          editable="false" wrapText="false"/>
            </VBox>
        </SplitPane>
    </center>

</BorderPane>